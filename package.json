{
  "name": "deck-builder",
  "version": "0.1.0",
  "description": "Turn a dot-dash outline + a theme (colors, fonts, logo) into a self-contained HTML presentation. General-purpose; ships an academic-defence theme.",
  "type": "module",
  "bin": {
    "deck-builder": "bin/build.mjs"
  },
  "scripts": {
    "build": "node bin/build.mjs",
    "example": "node bin/build.mjs examples/thesis-defense.deck.md -o dist/thesis-defense.html"
  },
  "keywords": ["slides", "presentation", "deck", "markdown", "academic", "thesis-defence"],
  "license": "MIT",
  "dependencies": {
    "marked": "^12.0.0"
  }
}
